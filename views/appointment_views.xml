<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record model="ir.ui.view" id="view_hospital_appointment_tree">
        <field name="name">om.hospital.appointment.list</field>
        <field name="model">om.hospital.appointment</field>
        <field name="arch" type="xml">

            <list create="1">
                <field name="patient_id"/>
                <field name="reference"/>
                <field name="date_of_appointment" optional="show"/>
            </list>
        </field>
    </record>

     <record model="ir.ui.view" id="view_hospital_appointment_form">
        <field name="name">om.hospital.appointment.form</field>
        <field name="model">om.hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_ongoing" type="object" string="Ongoing"
                            invisible="state != 'confirmed'" class="oe_highlight"/>
                    <button name="action_done" type="object" string="Done"
                            invisible="state != 'ongoing'" class="oe_highlight"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state == 'done'" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,ongoing,done" />
                </header>
                <sheet>
                    <group>
                        <field name="patient_id"/>
                        <field name="reference" readonly="True"/>
                        <field name="date_of_appointment" optional="show"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>

            </form>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">om.hospital.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>