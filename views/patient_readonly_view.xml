<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.ui.view" id="view_hospital_patient_readonly_tree">
        <field name="name">hospital.patient.readonly.tree</field>
        <field name="model">om.hospital.patient</field>
        <field name="priority">5</field>
        <field name="arch" type="xml">

            <list create="0" edit="0" delete="0">
                <field name="name"/>   
                <field name="date_of_birth" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="email"/>
            </list>
        </field>


    </record>


    <record model="ir.ui.view" id="view_hospital_patient_readonly_form">
        <field name="name">hospital.patient.readonly.form</field>
        <field name="model">om.hospital.patient</field>

        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date_of_birth" optional="show"/>
                    </group>
                    <group>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>


            </form>
        </field>
    </record>

    <record id="action_hospital_patient_readonly" model="ir.actions.act_window">
        <field name="name">View Patient</field>
        <field name="res_model">om.hospital.patient</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[ (5, 0, 0),
    (0, 0, {'view_mode': 'list', 'view_id': ref('view_hospital_patient_readonly_tree')}),
    (0, 0, {'view_mode': 'form', 'view_id': ref('view_hospital_patient_readonly_form')})]"
        />
        <!--        <field name="view_id" ref="view_hospital_patient_readonly_tree"/>-->

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new patient!
            </p>
        </field>
    </record>

</odoo>