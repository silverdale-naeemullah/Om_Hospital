<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.ui.view" id="view_hospital_patient_tag_tree">
        <field name="name">hospital.patient.tag.tree</field>
        <field name="model">om.hospital.patient.tag</field>
        <field name="arch" type="xml">

            <list create="1" >
                <field name="name"/>

            </list>
        </field>

    </record>


 <record id="action_patient_tag" model="ir.actions.act_window">
        <field name="name">Patient Tag</field>
        <field name="res_model">om.hospital.patient.tag</field>

        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new patient!
            </p>
        </field>
    </record>
</odoo>